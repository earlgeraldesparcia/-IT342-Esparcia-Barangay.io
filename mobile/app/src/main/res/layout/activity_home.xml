<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Top Blue Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#155EAF"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvWelcomeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good day!"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded_border_white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Office Hours: Monday–Friday, 8:00 AM – 5:00 PM (except holidays)"
                android:textColor="#E0E7FF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Next Appointment Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNextAppointment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next appointment"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:drawableStartCompat="@android:drawable/ic_menu_today"
                    android:drawablePadding="8dp" />

                <LinearLayout
                    android:id="@+id/layoutNoUpcoming"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No upcoming appointments."
                        android:textColor="#64748B" />

                    <TextView
                        android:id="@+id/tvBookNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Book an appointment now"
                        android:textColor="#155EAF"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutUpcomingAppt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="16dp">

                    <TextView
                        android:id="@+id/tvUpcomingType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Certificate Type"
                        android:textStyle="bold"
                        android:textColor="#333333" />
                    
                    <TextView
                        android:id="@+id/tvUpcomingDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date - Time"
                        android:textColor="#666666" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Completed Requests Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCompletedRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed requests"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:drawableStartCompat="@android:drawable/ic_menu_agenda"
                    android:drawablePadding="8dp" />

                <!-- Placeholder for completed request -->
                <LinearLayout
                    android:id="@+id/layoutCompletedRequest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#F8FAFC"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="#3B82F6" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCompletedType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Certificate Of Indigency"
                            android:textColor="#0F172A"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvCompletedDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2026-05-10"
                                android:textColor="#64748B"
                                android:textSize="12sp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#10B981"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="Completed"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNoCompleted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="No completed requests yet."
                    android:textColor="#64748B" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Barangay Services Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Barangay services"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Barangay Clearance" android:textColor="#475569" android:layout_marginBottom="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Certificate of Indigency" android:textColor="#475569" android:layout_marginBottom="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Community Tax Certificate" android:textColor="#475569" android:layout_marginBottom="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Solo Parent Certificate" android:textColor="#475569" android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnBookAppointment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#155EAF"
                    android:text="Book appointment"
                    android:textAllCaps="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="Contact information"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Barangay office"
                    android:textColor="#0F172A"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email: apas@barangay.io" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phone: (032) 123-4567" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Address: UCMA Village, Apas, Cebu City, Cebu 6000" android:textColor="#475569" android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#FEE2E2"
            android:text="Log out"
            android:textAllCaps="false"
            android:textColor="#EF4444" />

    </LinearLayout>
</ScrollView>
